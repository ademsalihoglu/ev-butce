rules_version = '2';
// Deploy with: firebase deploy --only firestore:rules
// (Requires firebase-tools + firebase init firestore in this directory.)
//
// Schema:
//   users/{userId}                            — private per-user state (activeGroupId, etc.)
//   groups/{groupId}                          — group document with memberIds, ownerId, inviteCode
//   groups/{groupId}/members/{userId}         — member metadata (displayName, role, joinedAt)
//   groups/{groupId}/{collection}/{docId}     — shared data (categories, transactions, shoppingItems, notes, assets)
//   invites/{code}                            — { groupId, createdBy } lookup doc for join-by-code flow

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isGroupMember(groupId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/groups/$(groupId))
        && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;
    }

    // Per-user private state.
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Invite code lookup: any signed-in user can read an invite to discover
    // the groupId it belongs to. Only the creator can write/delete invites.
    match /invites/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.createdBy == request.auth.uid;
      allow delete: if isSignedIn()
        && resource.data.createdBy == request.auth.uid;
    }

    // Group documents.
    match /groups/{groupId} {
      // Read a group if you are already a member (to see its data) OR if you
      // just hold a valid invite code — we allow one-shot get for any signed-in
      // user so the join flow can fetch the group doc before writing memberIds.
      allow get: if isSignedIn();
      allow list: if isSignedIn()
        && request.auth.uid in resource.data.memberIds;

      // Create: user must set themselves as ownerId and be the sole initial member.
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.memberIds.size() == 1
        && request.resource.data.memberIds[0] == request.auth.uid;

      // Update:
      //  (a) owner can change anything
      //  (b) any signed-in user may add themselves to memberIds (join)
      //  (c) any member may remove themselves from memberIds (leave)
      allow update: if isSignedIn()
        && (
          request.auth.uid == resource.data.ownerId
          || (
            // self-add: only memberIds changes, adding exactly self, other fields intact
            request.resource.data.ownerId == resource.data.ownerId
            && request.resource.data.name == resource.data.name
            && request.resource.data.inviteCode == resource.data.inviteCode
            && request.resource.data.memberIds.hasAll(resource.data.memberIds)
            && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1
            && !(request.auth.uid in resource.data.memberIds)
            && request.auth.uid in request.resource.data.memberIds
          )
          || (
            // self-leave: only memberIds shrinks by exactly self
            request.auth.uid in resource.data.memberIds
            && !(request.auth.uid in request.resource.data.memberIds)
            && resource.data.memberIds.hasAll(request.resource.data.memberIds)
            && request.resource.data.memberIds.size() == resource.data.memberIds.size() - 1
            && request.resource.data.ownerId == resource.data.ownerId
            && request.resource.data.name == resource.data.name
          )
        );

      // Delete: only the owner.
      allow delete: if isSignedIn() && request.auth.uid == resource.data.ownerId;

      // Members subcollection.
      match /members/{memberUserId} {
        allow read: if isGroupMember(groupId);
        // A user writes their own member profile on join; owner can remove anyone.
        allow create: if isSignedIn() && request.auth.uid == memberUserId;
        allow update: if isSignedIn() && request.auth.uid == memberUserId;
        allow delete: if isSignedIn()
          && (
            request.auth.uid == memberUserId
            || request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId
          );
      }

      // Shared app data: only members can read or write.
      match /categories/{docId}    { allow read, write: if isGroupMember(groupId); }
      match /transactions/{docId}  { allow read, write: if isGroupMember(groupId); }
      match /shoppingItems/{docId} { allow read, write: if isGroupMember(groupId); }
      match /notes/{docId}         { allow read, write: if isGroupMember(groupId); }
      match /assets/{docId}        { allow read, write: if isGroupMember(groupId); }
    }
  }
}
