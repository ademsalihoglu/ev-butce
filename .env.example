EXPO_PUBLIC_FIREBASE_API_KEY=your-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=project
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional — OCR.Space free API key for receipt/fiş OCR ("Fişten doldur" butonu).
# Anahtar yoksa paylaşılan demo anahtarı (helloworld) kullanılır (hız/boyut sınırlı).
# Ücretsiz anahtar için: https://ocr.space/ocrapi/freekey
EXPO_PUBLIC_OCRSPACE_API_KEY=
